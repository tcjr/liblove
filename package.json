{
  "name": "liblove",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for liblove goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"pnpm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "netlify dev",
    "start:ember": "vite",
    "test": "vite build --mode development && ember test --path dist"
  },
  "imports": {
    "#app/*": "./app/*",
    "#tests/*": "./tests/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.28.5",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/runtime": "^7.28.6",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.15",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.5",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.1",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.6.1",
    "@eslint/js": "^9.34.0",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.2.2",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.2.3",
    "@rollup/plugin-babel": "^6.0.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/qunit": "^2.19.13",
    "@types/rsvp": "^4.0.9",
    "@warp-drive/core": "^5.8.1",
    "@warp-drive/ember": "^5.8.1",
    "@warp-drive/json-api": "^5.8.1",
    "@warp-drive/legacy": "^5.8.1",
    "@warp-drive/utilities": "^5.8.1",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "baseline-browser-mapping": "^2.10.10",
    "concurrently": "^9.2.1",
    "daisyui": "^5.1.28",
    "decorator-transforms": "^2.3.0",
    "ember-auto-import": "^2.10.0",
    "ember-cli": "~6.11.0",
    "ember-cli-babel": "^8.3.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.3",
    "ember-resolver": "^13.2.0",
    "ember-resources": "^7.0.7",
    "ember-source": "~6.11.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.3",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-qunit": "^8.2.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "prettier-plugin-ember-template-tag": "^2.1.0",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.5.0",
    "reactiveweb": "^1.9.0",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^38.0.0",
    "tailwindcss": "^4.0.0",
    "testem": "^3.16.0",
    "tracked-built-ins": "^4.0.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">= 18"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "@netlify/functions": "^4.2.7",
    "@netlify/neon": "^0.1.0"
  }
