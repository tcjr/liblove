{
  "extends": "@ember/app-tsconfig",
  "include": ["app", "tests", "types"],
  "compilerOptions": {
    "allowJs": true,
    "paths": {
      "liblove/tests/*": ["./tests/*"],
      "liblove/*": ["./app/*"],
      "#app/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "types": [
      "ember-source/types",
      "node",
      "@embroider/core/virtual",
      "vite/client"
    ],
    "allowImportingTsExtensions": true
  }
}
