{
  "extends": "@ember/app-tsconfig",
  "include": ["app", "tests", "types"],
  "compilerOptions": {
    "allowJs": true,
    "paths": {
      "#app/*": ["./app/*"],
      "#tests/*": ["./tests/*"],
      "*": ["./types/*"]
    },
    "types": [
      "ember-source/types",
      // "node",
      "@embroider/core/virtual",
      "vite/client",
      "@glint/ember-tsc/types"
    ],
    "allowImportingTsExtensions": true
  }
}
